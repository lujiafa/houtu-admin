<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.houtu.mp.module.sys.dao.SysUserDao">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.houtu.mp.module.sys.entity.SysUserEntity">
        <id column="user_id" property="userId" />
        <result column="user_name" property="userName" />
        <result column="nick_name" property="nickName" />
        <result column="email" property="email" />
        <result column="phone" property="phone" />
        <result column="avatar" property="avatar" />
        <result column="password" property="password" />
        <result column="google_otp_key" property="googleOTPKey" />
        <result column="enable_mfa" property="enableMFA" />
        <result column="status" property="status" />
        <result column="deleted" property="deleted" />
        <result column="create_by" property="createBy" />
        <result column="create_time" property="createTime" />
        <result column="update_by" property="updateBy" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        su.user_id, su.user_name, su.nick_name, su.email, su.phone, su.avatar, su.`password`, su.enable_mfa, su.google_otp_key, su.`status`, su.deleted, su.create_by, su.create_time, su.update_by, su.update_time
    </sql>

    <select id="queryPage" resultMap="BaseResultMap">
        select distinct
        <include refid="Base_Column_List"/>
        from sys_user su
        <if test="params.orgIds != null and params.orgIds.size() > 0">
            inner join sys_user_org suo on su.user_id = suo.user_id
        </if>
        where su.deleted = 0
        <if test="params.orgIds != null and params.orgIds.size() > 0">
            and suo.org_id in
            <foreach collection="params.orgIds" item="orgId" index="index" open="(" separator="," close=")">
                #{orgId}
            </foreach>
        </if>
        <if test="params.nickName != null and params.nickName != ''">
            and nick_name like concat(#{params.nickName}, '%')
        </if>
        <if test="params.userName != null and params.userName != ''">
            and user_name like concat#{params.userName}, '%')
        </if>
        <if test="params.status != null">
            and status = #{params.status}
        </if>
    </select>

</mapper>
