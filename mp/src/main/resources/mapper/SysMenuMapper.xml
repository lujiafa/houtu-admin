<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.houtu.mp.module.sys.dao.SysMenuDao">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.houtu.mp.module.sys.entity.SysMenuEntity">
        <id column="menu_id" property="menuId" />
        <result column="menu_name" property="menuName" />
        <result column="parent_id" property="parentId" />
        <result column="menu_type" property="menuType" />
        <result column="sort" property="sort" />
        <result column="path_type" property="pathType" />
        <result column="path" property="path" />
        <result column="perms" property="perms" />
        <result column="icon_type" property="iconType" />
        <result column="icon" property="icon" />
        <result column="status" property="status" />
        <result column="deleted" property="deleted" />
        <result column="create_by" property="createBy" />
        <result column="create_time" property="createTime" />
        <result column="update_by" property="updateBy" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        menu_id, menu_name, parent_id, menu_type, sort, path_type, `path`, perms, icon_type, icon, `status`, deleted, create_by, create_time, update_by, update_time
    </sql>


    <select id="queryMenuByRoleIds" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from sys_menu
        where deleted = 0
        <if test="status != null">
            and status = #{status}
        </if>
        <if test="menuTypes != null and menuTypes.size() > 0">
            and menu_type in
            <foreach collection="menuTypes" item="menuType" open="(" separator="," close=")">
                #{menuType}
            </foreach>
        </if>
        and menu_id in (
        select menu_id from sys_role_menu where role_id in
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
        )
        order by `sort`
    </select>

    <update id="updateById" parameterType="com.houtu.mp.module.sys.entity.SysMenuEntity">
        update sys_menu set
        perms=#{perms},
        <if test="menuName != null">
            menu_name = #{menuName},
        </if>
        <if test="parentId != null">
            parent_id = #{parentId},
        </if>
        <if test="sort != null">
            sort = #{sort},
        </if>
        <if test="status != null">
            status = #{status},
        </if>
        <if test="pathType != null">
            path_type = #{pathType},
        </if>
        <if test="path != null">
            path = #{path},
        </if>
        <if test="iconType != null">
            icon_type = #{iconType},
        </if>
        <if test="icon != null">
            icon = #{icon},
        </if>
        update_time = #{updateTime},
        update_by = #{updateBy}
        where menu_id = #{menuId}
    </update>

</mapper>
